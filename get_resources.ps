param(
    [Parameter(Mandatory = $true)]
    [string]$SubscriptionId,

    [Parameter(Mandatory = $true)]
    [string]$ResourceGroupName
)

Write-Host "Setting Azure subscription..."
Set-AzContext -SubscriptionId $SubscriptionId

Write-Host "Fetching resource groups: $ResourceGroupName"

$resources = Get-AzResource -ResourceGroupName $ResourceGroupName

if ($resources.Count -eq 0) {
    Write-Host "No resources found in the resource group."
}
else {
    $resources | Select-Object Name, ResourceType, Location |
        Format-Table -AutoSize
}

# Export resource list if required
$resources | Select-Object Name, ResourceType, Location |
    Export-Csv -Path "./resources.csv" -NoTypeInformation

Write-Host "Resource details exported to resources.csv"
